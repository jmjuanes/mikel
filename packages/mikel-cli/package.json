{
    "name": "mikel-cli",
    "description": "The cli tool for mikel templating.",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Josemi Juanes",
        "email": "hello@josemi.xyz"
    },
    "repository": {
        "url": "https://github.com/jmjuanes/mikel",
        "directory": "packages/mikel-cli"
    },
    "bugs": "https://github.com/jmjuanes/mikel/issues",
    "engines": {
        "node": ">=24.0.0"
    },
    "types": "index.d.ts",
    "scripts": {
        "test": "node --import=./loader.js test.js"
    },
    "exports": {
        ".": {
            "import": "./index.js",
            "types": "./index.d.ts"
        },
        "./index.js": {
            "import": "./index.js",
            "types": "./index.d.ts"
        },
        "./package.json": "./package.json"
    },
    "bin": {
        "mikel": "cli.js"
    },
    "peerDependencies": {
        "mikel": "*"
    },
    "files": [
        "README.md",
        "cli.js",
        "index.js",
        "index.d.ts"
    ],
    "keywords": [
        "mikel",
        "cli",
        "templating"
    ]
}
